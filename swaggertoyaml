# convert_swagger_yaml_to_json.py

import json
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    print("Missing dependency. Install it with:")
    print("pip install pyyaml")
    sys.exit(1)


def convert_yaml_to_json(input_file: str, output_file: str | None = None):
    input_path = Path(input_file)

    if not input_path.exists():
        print(f"File not found: {input_file}")
        sys.exit(1)

    if output_file is None:
        output_file = input_path.with_suffix(".json")

    with open(input_path, "r", encoding="utf-8") as f:
        yaml_data = yaml.safe_load(f)

    with open(output_file, "w", encoding="utf-8") as f:
        json.dump(yaml_data, f, indent=2, ensure_ascii=False)

    print(f"Converted successfully: {output_file}")


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage:")
        print("python convert_swagger_yaml_to_json.py swagger.yaml")
        print("python convert_swagger_yaml_to_json.py swagger.yaml output.json")
        sys.exit(1)

    input_yaml = sys.argv[1]
    output_json = sys.argv[2] if len(sys.argv) > 2 else None

    convert_yaml_to_json(input_yaml, output_json)
