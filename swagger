import json
import sys
from pathlib import Path
from datetime import date, datetime

import yaml


def json_serializer(obj):
    if isinstance(obj, (datetime, date)):
        return obj.isoformat()
    return str(obj)


def convert_yaml_to_json(input_file, output_file=None):
    input_path = Path(input_file)

    if not input_path.exists():
        print(f"File not found: {input_file}")
        sys.exit(1)

    if output_file is None:
        output_file = input_path.with_suffix(".json")

    with open(input_path, "r", encoding="utf-8") as f:
        yaml_data = yaml.safe_load(f)

    with open(output_file, "w", encoding="utf-8") as f:
        json.dump(
            yaml_data,
            f,
            indent=2,
            ensure_ascii=False,
            default=json_serializer
        )

    print(f"Converted successfully: {output_file}")


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage:")
        print("python3 swaggertoyaml.py swagger.yaml")
        print("python3 swaggertoyaml.py swagger.yaml swagger.json")
        sys.exit(1)

    input_yaml = sys.argv[1]
    output_json = sys.argv[2] if len(sys.argv) > 2 else None

    convert_yaml_to_json(input_yaml, output_json)
